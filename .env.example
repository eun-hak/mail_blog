# API 서버 포트 (기본 3001 — Next.js 3000과 충돌 방지)
PORT=3001

# Gemini API (Gmail → 블로그 변환)
GEMINI_API_KEY=
# API 호출 간격(ms). 무료 tier 15req/min — 기본 6500
GEMINI_REQUEST_DELAY_MS=6500

# 프론트엔드 origin (쉼표로 여러 개 가능)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# CLI / API 공통 Gmail 검색 (선택)
# 비우면 UPPITY + DAILY_BYTE 두 발신자만 검색 (기본)
# GMAIL_QUERY=(from:moneyletter@uppity.co.kr OR from:byteteam365@mydailybyte.com) newer_than:30d
GMAIL_MAX_RESULTS=10
