# API 서버 포트 (기본 3002 — 3001은 다른 Next 앱과 충돌하는 경우가 많음)
PORT=3002

# Gemini API (Gmail → 블로그 변환)
GEMINI_API_KEY=
# API 호출 간격(ms). 무료 tier 15req/min — 기본 6500
GEMINI_REQUEST_DELAY_MS=6500

# Unsplash (글 썸네일 검색) — https://unsplash.com/developers
# Demo: 시간당 50회. 이 프로젝트는 ACCESS_KEY만 사용 (Client-ID 검색 API)
UNSPLASH_ID=
UNSPLASH_ACCESS_KEY=
UNSPLASH_SECRET_KEY=

# NVIDIA Flux (글 썸네일 AI 생성, 권장) — https://build.nvidia.com
# black-forest-labs/flux.1-schnell
NVIDIA_API_KEY=
# 품질 검증 실패 시 재시도 횟수 (기본 3)
# FLUX_MAX_ATTEMPTS=3

# 프론트엔드 origin (쉼표로 여러 개 가능)
CORS_ORIGIN=http://localhost:5173,http://localhost:3000

# CLI / API 공통 Gmail 검색 (선택)
# 비우면 UPPITY + DAILY_BYTE 두 발신자만 검색 (기본)
# GMAIL_QUERY=(from:moneyletter@uppity.co.kr OR from:byteteam365@mydailybyte.com) newer_than:30d
GMAIL_MAX_RESULTS=10
